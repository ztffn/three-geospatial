# Environment template for the Huma twin globe (twin.humatopia.ai + unitech).
# Copy to .env (gitignored) and fill in real values. NEVER commit .env.
# Browser-exposed map tokens (VITE_/STORYBOOK_) are provider-restricted by
# referrer/key scope. BarentsWatch + FROST are REAL OAuth secrets, server-side
# only — they live in the container env (/opt/huma-twin/.env), not build-args.

# === Basemap / 3D tiles ======================================================
STORYBOOK_ION_API_TOKEN=        # Cesium Ion token (terrain/3D tiles)
STORYBOOK_GOOGLE_MAP_API_KEY=   # Google Maps key (Storybook/dev)
VITE_GOOGLE_MAPS_API_KEY=       # Google Maps key (app bundle)

# === MET / FROST weather (OAuth client) ======================================
FROST_CLIENT_ID=
FROST_CLIENT_SECRET=

# === BarentsWatch live AIS (OAuth client) ====================================
# Required for the live-AIS vessel layer. Exchanged for a bearer token at
# request time server-side; runtime env, not build-args.
BARENTSWATCH_CLIENT_ID=
BARENTSWATCH_CLIENT_SECRET=
