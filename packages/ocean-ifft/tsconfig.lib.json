{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc/ocean-ifft",
    "declaration": false,
    "allowJs": true,
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js",
    "components/**/*.ts",
    "components/**/*.tsx",
    "components/**/*.js"
  ],
  "exclude": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.stories.tsx",
    "dist",
    "node_modules"
  ]
}
